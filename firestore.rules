rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && userRole() == 'admin';
    }

    function isOrganizer() {
      return isAuth() && (userRole() == 'organizer' || userRole() == 'admin');
    }

    // ── EVENTS ────────────────────────────────────────────────────────────────
    match /events/{eventId} {
      // Herkes onaylı ve arşivlenmemiş etkinlikleri okuyabilir
      allow read: if resource.data.status == 'approved' && resource.data.archived != true
                  || isAdmin()
                  || (isOrganizer() && resource.data.organizerId == request.auth.uid);

      // Organizatörler beklemede (pending) etkinlik oluşturabilir
      allow create: if isOrganizer()
                    && request.resource.data.status == 'pending'
                    && request.resource.data.organizerId == request.auth.uid;

      // Organizatör kendi etkinliğini güncelleyebilir (rol değişikliği hariç)
      // Herhangi bir kullanıcı sadece viewCount alanını artırabilir
      allow update: if isAdmin()
                    || (isOrganizer() && resource.data.organizerId == request.auth.uid)
                    || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']));

      allow delete: if isAdmin();

      // Reviews alt koleksiyonu
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAuth() && resource.data.userId == request.auth.uid
                              || isAdmin();
      }

      // Reservations alt koleksiyonu (koltuk seçimi için)
      match /reservations/{reservationId} {
        allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
        allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    // ── USERS ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth() && (isOwner(userId) || isAdmin());
      allow create: if isAuth() && isOwner(userId);

      // Kullanıcı kendi profilini güncelleyebilir, AMA rol alanını değiştiremez
      allow update: if isAuth() && isOwner(userId)
                      && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
                    || isAdmin();

      allow delete: if isAdmin();
    }

    // ── CLUBS ─────────────────────────────────────────────────────────────────
    match /clubs/{clubId} {
      allow read: if resource.data.status == 'approved' || isAdmin();
      allow create: if isAuth() && request.resource.data.status == 'pending';

      allow update: if isAdmin()
                    || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']));

      allow delete: if isAdmin();
    }

    // ── COURSES ───────────────────────────────────────────────────────────────
    match /courses/{courseId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── REGISTRATIONS (Kurs kayıtları) ────────────────────────────────────────
    match /registrations/{regId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── RESERVATIONS (Üst düzey) ──────────────────────────────────────────────
    match /reservations/{reservationId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── ORDERS ────────────────────────────────────────────────────────────────
    // Siparişler sunucu tarafında (Admin SDK) oluşturulur.
    // Kullanıcılar yalnızca kendi siparişlerini okuyabilir.
    match /orders/{orderId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false; // Yalnızca Admin SDK
    }

    // ── QUESTIONS ─────────────────────────────────────────────────────────────
    match /questions/{questionId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
    }

    // ── NOTIFICATIONS ─────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read, update, delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
    }

    // ── SPONSORS ──────────────────────────────────────────────────────────────
    match /sponsors/{sponsorId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // ── STATS (ViewTracker için) ──────────────────────────────────────────────
    match /stats/{statId} {
      allow read: if true;
      allow write: if isAuth(); // ViewTracker authenticated kullanıcıdan yazıyor
    }

    // ── BALANCES (Organizatör bakiyeleri) ─────────────────────────────────────
    match /balances/{userId} {
      allow read: if isAuth() && (isOwner(userId) || isAdmin());
      allow write: if false; // Yalnızca Admin SDK
    }

    // ── PAYOUTS ───────────────────────────────────────────────────────────────
    match /payouts/{payoutId} {
      allow read: if isAuth() && (resource.data.organizerId == request.auth.uid || isAdmin());
      allow write: if false; // Yalnızca Admin SDK
    }

    // ── DISCOUNT CODES ────────────────────────────────────────────────────────
    // İndirim kodları doğrulaması sunucu tarafında yapılır, client erişimi yok
    match /discountCodes/{codeId} {
      allow read, write: if false;
    }

    match /discountCodeUsage/{usageId} {
      allow read, write: if false;
    }

    // ── AUDIT LOGS ────────────────────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Yalnızca Admin SDK
    }

    // ── ORGANIZER APPLICATIONS ────────────────────────────────────────────────
    match /organizer_applications/{appId} {
      allow create: if isAuth();
      allow read, update, delete: if isAdmin();
    }

    // ── CLUB APPLICATIONS ─────────────────────────────────────────────────────
    match /club_applications/{appId} {
      allow create: if isAuth();
      allow read, update, delete: if isAdmin();
    }

  }
}
