rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function userRole() {
      // Kullanıcı dokümanı henüz yoksa (yeni kayıt) 'user' döndür
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'user';
    }

    function isAdmin() {
      return isAuth() && userRole() == 'admin';
    }

    function isOrganizer() {
      return isAuth() && (userRole() == 'organizer' || userRole() == 'admin');
    }

    // ── EVENTS ────────────────────────────────────────────────────────────────
    match /events/{eventId} {
      // Herkese açık okuma — approved events (arşiv filtresi client-side yapılır)
      allow read: if resource.data.status == 'approved'
                  || isAdmin()
                  || (isOrganizer() && resource.data.organizerId == request.auth.uid);

      // Organizatörler pending etkinlik oluşturabilir
      allow create: if isOrganizer()
                    && request.resource.data.status == 'pending'
                    && request.resource.data.organizerId == request.auth.uid;

      // Admin veya kendi etkinliğini güncelleyen organizatör
      // Herhangi bir kullanıcı sadece viewCount artırabilir
      allow update: if isAdmin()
                    || (isOrganizer() && resource.data.organizerId == request.auth.uid)
                    || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']);

      allow delete: if isAdmin();

      // Reviews alt koleksiyonu
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAuth() && resource.data.userId == request.auth.uid
                              || isAdmin();
      }

      // Reservations alt koleksiyonu (koltuk seçimi)
      match /reservations/{reservationId} {
        allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
        allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    // ── USERS ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth() && (isOwner(userId) || isAdmin());
      allow create: if isAuth() && isOwner(userId);

      // Kullanıcı kendi profilini güncelleyebilir, AMA 'role' alanını değiştiremez
      allow update: if isAuth() && isOwner(userId)
                      && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
                    || isAdmin();

      allow delete: if isAdmin();
    }

    // ── CLUBS ─────────────────────────────────────────────────────────────────
    match /clubs/{clubId} {
      // Approved kulüpler herkese açık — query'de where("status","==","approved") olduğu için
      allow read: if resource.data.status == 'approved' || isAdmin();
      allow create: if isAuth() && request.resource.data.status == 'pending';

      allow update: if isAdmin()
                    || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']);

      allow delete: if isAdmin();
    }

    // ── COURSES ───────────────────────────────────────────────────────────────
    match /courses/{courseId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── REGISTRATIONS (Kurs kayıtları) ────────────────────────────────────────
    match /registrations/{regId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── RESERVATIONS (Üst düzey) ──────────────────────────────────────────────
    match /reservations/{reservationId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── ORDERS ────────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false; // Yalnızca Admin SDK
    }

    // ── REVIEWS (Top-level collection) ───────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid
                            || isAdmin();
    }

    // ── QUESTIONS ─────────────────────────────────────────────────────────────
    match /questions/{questionId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
    }

    // ── NOTIFICATIONS ─────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read, update, delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
    }

    // ── SPONSORS ──────────────────────────────────────────────────────────────
    match /sponsors/{sponsorId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // ── STATS (ViewTracker) ───────────────────────────────────────────────────
    match /stats/{statId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // ── BALANCES ──────────────────────────────────────────────────────────────
    match /balances/{userId} {
      allow read: if isAuth() && (isOwner(userId) || isAdmin());
      allow write: if false;
    }

    // ── PAYOUTS ───────────────────────────────────────────────────────────────
    match /payouts/{payoutId} {
      allow read: if isAuth() && (resource.data.organizerId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ── DISCOUNT CODES ────────────────────────────────────────────────────────
    match /discountCodes/{codeId} {
      allow read, write: if false;
    }

    match /discountCodeUsage/{usageId} {
      allow read, write: if false;
    }

    // ── AUDIT LOGS ────────────────────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── ORGANIZER APPLICATIONS ────────────────────────────────────────────────
    match /organizer_applications/{appId} {
      allow create: if isAuth();
      allow read, update, delete: if isAdmin();
    }

    // ── CLUB APPLICATIONS ─────────────────────────────────────────────────────
    match /club_applications/{appId} {
      allow create: if isAuth();
      allow read, update, delete: if isAdmin();
    }

  }
}
